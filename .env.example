OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memory_assistant
POSTGRES_USER=memory_user
POSTGRES_PASSWORD=memory_password

WEBCAM_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=24
FACE_DISTANCE_THRESHOLD=0.5
FACE_ABSENCE_TIMEOUT_SECONDS=8
FACE_FRAME_SCALE=0.5
FACE_MODEL=hog
FACE_UPSAMPLE=1
PROCESS_EVERY_N_FRAMES=3
FACE_PROCESS_INTERVAL_SECONDS=0.25
ASYNC_FACE_DETECTION=true
AUTO_NAME_NEW_PEOPLE=false
UNICODE_OVERLAY=true
SHOW_FPS=true

WHISPER_MODEL=small
WHISPER_LANGUAGE=vi
AUDIO_CHUNK_SECONDS=5
AUDIO_SAMPLE_RATE=16000
AUDIO_ENABLED=true

TTS_ENABLED=true
TTS_COOLDOWN_SECONDS=90
